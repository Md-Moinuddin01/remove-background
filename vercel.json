{
  "rewrites": [
    {
      "source": "/imgly-data/:path*",
      "destination": "https://staticimgly.com/@imgly/background-removal-data/1.7.0/dist/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    }
  ]
}
